# Copy to .env for local development.
# .env is gitignored — never commit real values.

PORT=3011
NODE_ENV=production

# Optional: point Puppeteer at a system Chromium instead of the bundled one.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Optional: override TTL (ms) for generated PDFs. Default: 1800000 (30 min).
# FILE_TTL_MS=1800000
